# Database Configuration
DB_HOST=your_host
DB_PORT=5433
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your_password

# App Configuration
APP_NAME=Dian QQ Bot
DEBUG=false
HOST=0.0.0.0
PORT=8000

# Docker Configuration
DOCKER_SOCKET=npipe:////./pipe/docker_engine
CONTAINER_PREFIX=dian
NAPCAT_IMAGE=mlikiowa/napcat-docker:latest

# Port Range
PORT_RANGE_START=30000
PORT_RANGE_END=40000

# Log Level
LOG_LEVEL=INFO
