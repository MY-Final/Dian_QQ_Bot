# 数据库模式选择
# local = 使用 .env 中的数据库配置（本地测试）
# remote = 使用 Setup 向导中配置的数据库（远程部署）
DB_MODE=local

# Database Configuration (当 DB_MODE=local 时生效)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dian_bot
DB_USER=postgres
DB_PASSWORD=your_password

# App Configuration
APP_NAME=Dian QQ Bot
DEBUG=false
HOST=0.0.0.0
PORT=8000
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:6173,http://127.0.0.1:6173

# Docker Configuration
DOCKER_SOCKET=npipe:////./pipe/docker_engine
CONTAINER_PREFIX=dian
NAPCAT_IMAGE=mlikiowa/napcat-docker:latest

# Port Range
PORT_RANGE_START=30000
PORT_RANGE_END=40000

# Log Level
LOG_LEVEL=INFO
