# 前端环境变量配置
# 复制此文件为 .env 并修改相应配置

# ============ API 配置 ============
# API 基础 URL（推荐使用相对路径，走 Vite/Nginx 代理）
VITE_API_BASE_URL=/api/v1

# 生产环境 API 地址（部署时修改）
# VITE_API_BASE_URL=https://your-domain.com/api/v1

# ============ 功能开关 ============
# 是否启用 Mock 数据（开发用）
VITE_USE_MOCK=false

# 是否启用调试模式
VITE_DEBUG=false

# ============ 应用配置 ============
# 应用标题
VITE_APP_TITLE=Dian QQ Bot - 点点

# 应用描述
VITE_APP_DESCRIPTION=QQ Bot 管理平台

# ============ 其他配置 ============
# WebSocket API 地址（可选）
# VITE_WS_URL=ws://127.0.0.1:8000/ws

# 最大上传文件大小（MB）
VITE_MAX_UPLOAD_SIZE=10
