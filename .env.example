# 环境变量配置示例
# 复制此文件为 .env 并修改相应配置

# ============ 数据库配置 ============
# PostgreSQL 数据库配置
DB_USER=postgres
DB_PASSWORD=Mima123456.@
DB_NAME=dian_bot
DB_PORT=5432

# ============ 应用配置 ============
# 调试模式（生产环境设为 false）
DEBUG=false

# 日志级别（INFO, DEBUG, WARNING, ERROR）
LOG_LEVEL=INFO

# ============ 端口配置 ============
# 后端 API 端口
API_PORT=8000

# 前端端口
FRONTEND_PORT=80

# ============ Docker 配置 ============
# Docker Socket 路径（Windows 使用 npipe:////./pipe/docker_engine）
DOCKER_SOCKET=/var/run/docker.sock

# 容器前缀
CONTAINER_PREFIX=dian

# NapCat 镜像
NAPCAT_IMAGE=mlikiowa/napcat-docker:latest

# Bot 实例端口范围
PORT_RANGE_START=30000
PORT_RANGE_END=40000
